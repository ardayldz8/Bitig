# Supabase (genel/publishable — istemcide kullanılır, RLS verini korur)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Yapay zeka — BİRİNCİL: OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Yapay zeka — YEDEK: Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Web Push (VAPID public key — gizli değil, istemcide kullanılır)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
